POSTGRES_DB=edge_controller
POSTGRES_USER=edge
POSTGRES_PASSWORD=change-me

DNS_ZONE=home.arpa
DNS_WILDCARD=*.home.arpa
EDGE_IP=192.168.2.10
TECHNITIUM_STATUS=Not configured

CADDY_ADMIN_ADDRESS=http://caddy:2019
CADDY_CONFIG_PATH=/etc/caddy/Caddyfile
